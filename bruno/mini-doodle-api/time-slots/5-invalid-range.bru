meta {
  name: 5. Create Slot - Invalid Range (409)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "startTime": "2025-03-03T10:00:00",
    "endTime": "2025-03-03T09:00:00"
  }
}

tests {
  test("Status is 409", () => {
    expect(res.status).to.equal(409);
  });
  test("Mentions end time", () => {
    expect(res.body.message).to.include("End time");
  });
}

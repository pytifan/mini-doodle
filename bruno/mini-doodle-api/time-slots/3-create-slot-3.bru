meta {
  name: 3. Create Slot - 14:00-15:00
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "startTime": "2025-03-03T14:00:00",
    "endTime": "2025-03-03T15:00:00"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("slot3Id", res.body.id);
  }
}

tests {
  test("Status is 201", () => {
    expect(res.status).to.equal(201);
  });
}

meta {
  name: 2. Book Meeting - Already Busy (409)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots/{{slot2Id}}/meetings
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "title": "Should Fail",
    "participantIds": []
  }
}

tests {
  test("Status is 409", () => {
    expect(res.status).to.equal(409);
  });
  test("Mentions busy", () => {
    expect(res.body.message).to.include("busy");
  });
}

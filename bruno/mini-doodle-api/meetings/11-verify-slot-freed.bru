meta {
  name: 11. Verify Slot FREE after Cancel
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots/{{slot2Id}}
  body: none
  auth: none
}

tests {
  test("Status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("Slot is FREE", () => {
    expect(res.body.status).to.equal("FREE");
  });
  test("No meeting", () => {
    expect(res.body.hasMeeting).to.equal(false);
  });
}

meta {
  name: 9. Cannot Free Slot with Meeting (409)
  type: http
  seq: 9
}

patch {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots/{{slot2Id}}/status
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "status": "FREE"
  }
}

tests {
  test("Status is 409", () => {
    expect(res.status).to.equal(409);
  });
}

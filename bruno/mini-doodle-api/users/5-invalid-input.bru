meta {
  name: 5. Create User - Invalid Input (400)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/users
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "",
    "email": "not-an-email"
  }
}

tests {
  test("Status is 400", () => {
    expect(res.status).to.equal(400);
  });
  test("Has field errors", () => {
    expect(res.body.fieldErrors).to.exist;
  });
}

meta {
  name: 8. List All Users
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/v1/users?page=0&size=10
  body: none
  auth: none
}

params:query {
  page: 0
  size: 10
}

tests {
  test("Status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("Has content array", () => {
    expect(res.body.content).to.be.an("array");
  });
  test("Has pagination info", () => {
    expect(res.body.totalElements).to.exist;
    expect(res.body.totalPages).to.exist;
  });
}

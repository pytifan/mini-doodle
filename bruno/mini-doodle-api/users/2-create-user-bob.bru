meta {
  name: 2. Create User - Bob
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/users
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Bob Smith",
    "email": "bob@example.com"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("participantId", res.body.id);
  }
}

tests {
  test("Status is 201", () => {
    expect(res.status).to.equal(201);
  });
}

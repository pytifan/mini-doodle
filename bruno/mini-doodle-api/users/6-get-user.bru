meta {
  name: 6. Get User by ID
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/v1/users/{{userId}}
  body: none
  auth: none
}

tests {
  test("Status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("Correct user", () => {
    expect(res.body.name).to.equal("Alice Johnson");
  });
}

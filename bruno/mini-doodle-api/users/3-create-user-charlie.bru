meta {
  name: 3. Create User - Charlie
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/users
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Charlie Brown",
    "email": "charlie@example.com"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("participant2Id", res.body.id);
  }
}

tests {
  test("Status is 201", () => {
    expect(res.status).to.equal(201);
  });
}

meta {
  name: 8. List Slots - Filter FREE
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots?status=FREE
  body: none
  auth: none
}

params:query {
  status: FREE
}

tests {
  test("Status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("All slots are FREE", () => {
    res.body.content.forEach(s => {
      expect(s.status).to.equal("FREE");
    });
  });
}

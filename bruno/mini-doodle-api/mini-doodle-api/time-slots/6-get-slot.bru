meta {
  name: 6. Get Slot by ID
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots/{{slotId}}
  body: none
  auth: none
}

tests {
  test("Status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("Has correct fields", () => {
    expect(res.body.startTime).to.exist;
    expect(res.body.endTime).to.exist;
    expect(res.body.status).to.exist;
    expect(res.body.durationMinutes).to.exist;
  });
}

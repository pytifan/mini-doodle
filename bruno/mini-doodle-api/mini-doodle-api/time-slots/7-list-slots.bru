meta {
  name: 7. List All Slots
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots
  body: none
  auth: none
}

tests {
  test("Status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("Has 3 slots", () => {
    expect(res.body.content.length).to.equal(3);
  });
}

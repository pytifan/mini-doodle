meta {
  name: 10. Update Slot Time
  type: http
  seq: 10
}

put {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots/{{slotId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "startTime": "2025-03-03T08:30:00",
    "endTime": "2025-03-03T09:30:00"
  }
}

tests {
  test("Status is 200", () => {
    expect(res.status).to.equal(200);
  });
}

meta {
  name: 11. Mark Slot as BUSY
  type: http
  seq: 11
}

patch {
  url: {{baseUrl}}/api/v1/users/{{userId}}/slots/{{slot3Id}}/status
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "status": "BUSY"
  }
}

tests {
  test("Status is 200", () => {
    expect(res.status).to.equal(200);
  });
  test("Status is BUSY", () => {
    expect(res.body.status).to.equal("BUSY");
  });
}

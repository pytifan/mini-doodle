meta {
  name: 4. Create User - Duplicate Email (409)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/v1/users
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Alice Duplicate",
    "email": "alice@example.com"
  }
}

tests {
  test("Status is 409 Conflict", () => {
    expect(res.status).to.equal(409);
  });
}
